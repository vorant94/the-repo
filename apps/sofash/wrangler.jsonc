{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sofash",
  "main": "./src/main.ts",
  "compatibility_date": "2024-11-12",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sofash",
