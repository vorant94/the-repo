{
  "name": "sofash",
  "version": "0.0.1",
  "dependencies": {
    "@grammyjs/conversations": "^2.1.1",
    "@hono/standard-validator": "^0.2.3",
    "@hono/swagger-ui": "^0.6.1",
    "date-fns": "catalog:",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "catalog:",
    "grammy": "^1.45.1",
    "hono": "^4.12.31",
    "hono-openapi": "^1.3.1",
    "uuid": "^14.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:",
    "@total-typescript/ts-reset": "catalog:",
    "@types/node": "catalog:",
    "dotenv": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "wrangler": "catalog:"
  },
  "private": true,
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "deploy:production": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:production": "wrangler d1 migrations apply DB --remote",
    "proxy:dev": "ngrok http 5173",
    "start:dev": "vite",
    "ts:codegen": "pnpm run cf-typegen",
    "ts:check": "pnpm run ts:codegen && tsc"
  },
  "type": "module"
}
