{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["pnpm", "dlx", "chrome-devtools-mcp"]
    }
  }
}
