{
  "name": "the-repo",
  "devDependencies": {
    "@biomejs/biome": "^2.3.6",
    "knip": "^5.70.2",
    "lefthook": "^1.11.3",
    "skills": "^1.5.3"
  },
  "engines": {
    "node": ">=23"
  },
  "license": "MIT",
  "os": [
    "darwin",
    "linux"
  ],
  "packageManager": "pnpm@10.33.2",
  "private": true,
  "scripts": {
    "lint:check": "biome check .",
    "lint:ci": "biome ci .",
    "lint:write": "biome check --write .",
    "lint:write:unsafe": "biome check --write --unsafe .",
    "prepare": "lefthook install",
    "unused-code:check": "knip"
  },
  "type": "module"
}
